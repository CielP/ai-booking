DB_HOST=db
DB_PORT=5432
DB_USER=hotel
DB_PASSWORD=hotelpass
DB_NAME=hoteldb

PGADMIN_EMAIL=admin@hotel.com
PGADMIN_PASSWORD=adminpass

# JWT 設定
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d

# 初始 admin 帳號密碼（需與 docker/init.sql 中的 bcrypt hash 對應）
ADMIN_PASSWORD=admin123456

# AI 客服 API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
